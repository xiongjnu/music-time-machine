{
  "name": "music-time-machine",
  "version": "0.1.0",
  "description": "以年代为轴的音乐时光探索器",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "electron": "electron .",
    "electron-build": "electron-builder build --mac --win --linux"
  },
  "license": "MIT",
  "dependencies": {
    "@neteasecloudmusicapienhanced/api": "^4.32.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.musictime.machine",
    "productName": "Music Time Machine",
    "files": [
      "server/**/*",
      "client/**/*",
      "data/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
